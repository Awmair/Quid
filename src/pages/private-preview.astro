---
import '../styles/global.css';
import { Image } from 'astro:assets';
import wordmark from '../assets/brand/quid-wordmark.svg';
import mascot from '../assets/brand/quid-inquiry.png';

const title = 'Private Inquiry-to-Tour Preview | Quid';
const description = 'An unlisted preview of how Quid could handle inquiry follow-up and tour scheduling behind the scenes.';
const canonical = 'https://get-quid.site/private-preview/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow,noarchive,nosnippet" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Quid" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://get-quid.site/quid-og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://get-quid.site/quid-og.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body class="preview-body">
    <header class="preview-header">
      <div class="preview-shell preview-header-inner">
        <a href="/" aria-label="Quid home"><Image src={wordmark} alt="Quid" width={120} /></a>
        <span>Unlisted workflow preview</span>
      </div>
    </header>

    <main id="preview-content">
      <section class="preview-hero">
        <div class="preview-shell">
          <p class="eyebrow">Private inquiry-to-tour preview for</p>
          <h1 class="preview-community-title"><span data-community>Your community</span></h1>
          <div class="preview-context"><span data-location>Location not supplied</span><a data-website-link href="#" target="_blank" rel="noopener noreferrer">Website reviewed</a></div>

          <div class="preview-verdict-grid">
            <article class="preview-verdict problem">
              <span>The problem</span>
              <h2>Warm inquiries become more admin work.</h2>
              <p>Families may contact several communities while staff are busy with residents, tours, calls, and family questions. Routine follow-up can wait even when the team cares.</p>
              <div class="preview-chain danger"><b>Inquiry</b><i>→</i><b>Inbox wait</b><i>→</i><strong>Tour opportunity lost</strong></div>
            </article>
            <article class="preview-verdict solution">
              <Image src={mascot} alt="Quid moving an inquiry toward a tour" width={118} loading="eager" />
              <span>The Quid fit</span>
              <h2>Fewer missed inquiries. More booked tours. No extra admin hire.</h2>
              <p>Quid handles inquiry follow-up and tour scheduling behind the scenes without another daily tool for your team to manage.</p>
              <div class="preview-chain gain"><b>Inquiry</b><i>→</i><b>Fast response</b><i>→</i><strong>More tour opportunities</strong></div>
            </article>
          </div>

          <div class="preview-observation"><span>What we saw on your public website</span><p data-observation>Families can submit an inquiry, but the next step depends on manual staff follow-up.</p></div>
        </div>
      </section>

      <section class="preview-section preview-comparison">
        <div class="preview-shell">
          <div class="preview-section-head"><div><p class="eyebrow">The difference in one glance</p><h2>Your current path vs. the Quid path</h2></div><p>Same inquiry. Less chasing for staff.</p></div>
          <div class="preview-lanes">
            <article class="preview-lane current">
              <header><span>Current manual path</span><strong>Slow and easy to lose</strong></header>
              <div><b>1</b><span><strong data-cta>Request a Tour</strong> submitted</span></div><i>↓</i>
              <div><b>2</b><span>Form waits in an inbox</span></div><i>↓</i>
              <div><b>3</b><span>Staff replies when available</span></div><i>↓</i>
              <div><b>4</b><span>Calendar back-and-forth</span></div>
              <footer>Risk: the family books elsewhere first</footer>
            </article>
            <div class="preview-versus"><span>VS</span></div>
            <article class="preview-lane quid">
              <header><span>With Quid</span><strong>Immediate and trackable</strong></header>
              <div><b>1</b><span>Inquiry triggers approved workflow</span></div><i>↓</i>
              <div><b>2</b><span>Family receives an immediate reply</span></div><i>↓</i>
              <div><b>3</b><span>Approved tour times are offered</span></div><i>↓</i>
              <div><b>4</b><span>Follow-up runs; staff handles exceptions</span></div>
              <footer>Upside: routine work moves; staff handles people</footer>
            </article>
          </div>
        </div>
      </section>

      <section class="preview-revenue">
        <div class="preview-shell">
          <p class="eyebrow">The revenue path</p>
          <h2>Keep existing inquiries moving while staff focus on residents and families.</h2>
          <div class="preview-revenue-flow"><div><b>Existing demand</b><span>Families already finding you</span></div><i>→</i><div><b>Faster response</b><span>No waiting for inbox coverage</span></div><i>→</i><div><b>More tours</b><span>A clear next step while intent is high</span></div><i>→</i><div class="money"><b>More revenue opportunities</b><span>More chances to convert a move-in</span></div></div>
          <p class="preview-honesty">Quid does not invent demand or guarantee move-ins. It helps more of the demand you already have reach a visit.</p>
        </div>
      </section>

      <section class="preview-section preview-proof">
        <div class="preview-shell preview-proof-grid">
          <article class="preview-message">
            <span>Immediate acknowledgement</span>
            <p>Hi Sarah,</p>
            <p>Thank you for reaching out to <strong data-community>the community</strong>. We received your request.</p>
            <p>Choose a convenient time to visit below, or reply if you would rather speak with our team first.</p>
          </article>
          <article class="preview-tour-card">
            <span>Next step offered immediately</span>
            <h3>Visit <span data-community>the community</span></h3>
            <div class="preview-date-row"><button type="button">Tue<br /><strong>14</strong></button><button type="button">Wed<br /><strong>15</strong></button><button type="button">Thu<br /><strong>16</strong></button></div>
            <div class="preview-time-row"><span>10:00 AM</span><span>1:30 PM</span><span>3:00 PM</span></div>
          </article>
          <article class="preview-handoff-card">
            <span>Human review</span><h3>Important questions still go to people.</h3><p>Care, medication, eligibility and sensitive questions pause the workflow and alert staff.</p>
          </article>
        </div>
      </section>

      <section class="preview-section preview-final">
        <div class="preview-shell preview-final-grid">
          <div><p class="eyebrow">30-day focused pilot</p><h2>See what Quid can take off your team’s plate.</h2><p>One community. One inquiry source. One tour calendar. Measure missed-inquiry coverage, tours booked, and routine work handled behind the scenes.</p><a class="button" data-walkthrough-link href="mailto:charcopadart@gmail.com">See How Quid Fits</a></div>
          <article class="preview-price-card"><span>30-Day Quid Admissions Pilot</span><strong>$1,000</strong><small>one-time</small><hr /><p>Keep Quid for <b>$899/month per community</b> after the pilot.</p></article>
        </div>
      </section>

      <section class="preview-disclaimer">
        <div class="preview-shell">
          <p><strong>About this preview:</strong> This is an illustrative, unlisted workflow concept prepared from publicly available business information. It does not represent an active integration, endorsement, partnership, performance result or use of resident data. Final workflows require community review and approval.</p>
        </div>
      </section>
    </main>

    <section class="preview-invalid" data-invalid hidden>
      <Image src={wordmark} alt="Quid" width={140} />
      <h2>This preview link is incomplete.</h2>
      <p>Please reply to Umair and ask for a fresh link.</p>
    </section>

    <script is:inline>
      (() => {
        const raw = window.location.hash.replace(/^#/, '');
        const params = new URLSearchParams(raw);
        const clean = (value, max = 240) => (value || '').replace(/[<>\u0000-\u001F]/g, '').trim().slice(0, max);
        const community = clean(params.get('community'), 100);
        const location = clean(params.get('location'), 100) || 'United States';
        const observation = clean(params.get('observation'), 360) || 'Families can submit an inquiry, but the next step depends on manual staff follow-up.';
        const cta = clean(params.get('cta'), 60) || 'Request a Tour';
        const website = clean(params.get('website'), 260);

        if (!community) {
          document.querySelector('#preview-content')?.setAttribute('hidden', '');
          document.querySelector('.preview-header')?.setAttribute('hidden', '');
          const invalid = document.querySelector('[data-invalid]');
          if (invalid) invalid.removeAttribute('hidden');
          return;
        }

        document.querySelectorAll('[data-community]').forEach((node) => { node.textContent = community; });
        document.querySelectorAll('[data-location]').forEach((node) => { node.textContent = location; });
        document.querySelectorAll('[data-observation]').forEach((node) => { node.textContent = observation; });
        document.querySelectorAll('[data-cta]').forEach((node) => { node.textContent = cta; });
        const walkthroughLink = document.querySelector('[data-walkthrough-link]');
        if (walkthroughLink instanceof HTMLAnchorElement) {
          const subject = encodeURIComponent(`Quid walkthrough: ${community}`);
          const body = encodeURIComponent(`Hi Umair,\n\nI'd like to set up a walkthrough call for ${community}.\n\n`);
          walkthroughLink.href = `mailto:charcopadart@gmail.com?subject=${subject}&body=${body}`;
        }
        const link = document.querySelector('[data-website-link]');
        if (link instanceof HTMLAnchorElement) {
          try {
            const url = new URL(website);
            if (!['http:', 'https:'].includes(url.protocol)) throw new Error('Unsupported protocol');
            link.href = url.toString();
            link.textContent = `Website reviewed · ${url.hostname.replace(/^www\./, '')}`;
          } catch {
            link.removeAttribute('href');
            link.textContent = 'Public website reviewed';
          }
        }
        document.title = `${community} Inquiry-to-Tour Preview | Quid`;
      })();
    </script>
  </body>
</html>

<style>
  .preview-body { background: var(--cream); }
  .preview-shell { width: min(1120px, calc(100% - 40px)); margin-inline: auto; }
  .preview-header { position: sticky; top: 0; z-index: 50; border-bottom: 1px solid var(--border); background: rgba(251,247,239,.94); backdrop-filter: blur(14px); }
  .preview-header-inner { min-height: 68px; display: flex; align-items: center; justify-content: space-between; gap: 20px; }
  .preview-header a { text-decoration: none; }
  .preview-header span { color: var(--muted); font-size: .76rem; font-weight: 750; text-transform: uppercase; letter-spacing: .1em; }
  .preview-hero { padding: clamp(48px,7vw,92px) 0; overflow: hidden; background: radial-gradient(circle at 84% 20%, rgba(169,181,166,.5), transparent 32%), linear-gradient(135deg,var(--cream),#f4ecdf); }
  .preview-hero-grid { display: grid; grid-template-columns: 1.25fr .75fr; gap: clamp(30px,7vw,80px); align-items: center; }
  .preview-community-title { max-width: 16ch; margin: 10px 0 18px; font-size: clamp(2.8rem,6vw,5.8rem); line-height: .96; letter-spacing: -.045em; }
  .preview-community-title span { padding: .02em .08em .08em; background: linear-gradient(transparent 63%, rgba(237,177,144,.72) 63%); -webkit-box-decoration-break: clone; box-decoration-break: clone; }
  .preview-hero-kicker { margin: 0 0 16px; color: var(--ink); font: 650 clamp(1.25rem,2vw,1.7rem)/1.25 'Newsreader Variable',serif; }
  .preview-lede { max-width: 62ch; color: var(--muted); font-size: clamp(1.05rem,1.2vw,1.22rem); }
  .preview-context { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .preview-context span, .preview-context a { padding: 8px 11px; border: 1px solid var(--border); border-radius: 999px; background: rgba(255,253,248,.76); color: var(--muted); font-size: .75rem; font-weight: 700; text-decoration: none; }
  .preview-mascot-wrap { display: grid; place-items: center; min-height: 390px; }
  .preview-mascot-wrap img { max-height: 390px; object-fit: contain; filter: drop-shadow(0 22px 24px rgba(30,61,52,.14)); }
  .preview-section { padding: clamp(52px,7vw,86px) 0; }
  .preview-section h2 { margin-bottom: 26px; }
  .preview-section-sand { background: var(--sand); }
  .preview-section-sage { background: #e6ebe4; }
  .preview-section-deep { background: var(--ink); color: var(--cream); }
  .preview-section-deep h2 { color: var(--cream); }
  .preview-section-deep p { color: #dce4de; }
  .preview-section-deep .eyebrow { color: #edb190; }
  .preview-observation-grid { display: grid; grid-template-columns: .65fr 1.35fr; gap: 18px; align-items: stretch; }
  .preview-card { padding: 24px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--white); box-shadow: var(--shadow); }
  .preview-card-label { display: block; margin-bottom: 14px; color: var(--copper-dark); font-size: .7rem; font-weight: 800; text-transform: uppercase; letter-spacing: .1em; }
  .preview-card p { font-size: 1.05rem; }
  .preview-card small { display: block; color: var(--muted); }
  .preview-current-flow { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr; gap: 9px; align-items: center; padding: 22px; border-radius: var(--radius); background: rgba(255,253,248,.6); }
  .preview-current-flow > div { min-height: 126px; display: flex; flex-direction: column; justify-content: center; gap: 10px; padding: 15px; border: 1px solid var(--border); border-radius: 15px; background: var(--white); }
  .preview-current-flow b { width: 28px; height: 28px; display: grid; place-items: center; border-radius: 50%; background: var(--ink); color: var(--cream); font-size: .75rem; }
  .preview-current-flow span { font-size: .8rem; line-height: 1.42; }
  .preview-current-flow i { color: var(--copper-dark); font-size: 1.4rem; font-style: normal; }
  .preview-proposed-flow { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; }
  .preview-proposed-flow article { min-height: 218px; padding: 22px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--white); box-shadow: 0 12px 34px rgba(30,61,52,.07); }
  .preview-proposed-flow article > span { color: rgba(192,113,75,.4); font: 700 2.4rem/1 'Newsreader Variable',serif; }
  .preview-proposed-flow h3 { margin: 30px 0 8px; }
  .preview-proposed-flow p { color: var(--muted); font-size: .88rem; }
  .preview-message-grid { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(28px,6vw,70px); align-items: center; }
  .preview-message { padding: clamp(22px,4vw,38px); border: 1px solid rgba(255,255,255,.13); border-radius: var(--radius); background: var(--white); color: var(--ink); box-shadow: 0 26px 80px rgba(0,0,0,.2); }
  .preview-message > span { display: block; margin-bottom: 22px; color: var(--copper-dark); font-size: .7rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; }
  .preview-message p { color: var(--ink); }
  .preview-demo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .preview-tour-card, .preview-summary-card { padding: 25px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--white); box-shadow: var(--shadow); }
  .preview-window-head { display: flex; align-items: center; gap: 6px; margin: -4px 0 25px; padding-bottom: 14px; border-bottom: 1px solid var(--border); }
  .preview-window-head span { width: 9px; height: 9px; border-radius: 50%; background: var(--sand); }
  .preview-window-head b { margin-left: auto; color: var(--muted); font-size: .72rem; }
  .preview-date-row, .preview-time-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; margin-top: 16px; }
  .preview-date-row button, .preview-time-row span { min-height: 64px; display: grid; place-items: center; border: 1px solid var(--border); border-radius: 12px; background: var(--cream); color: var(--ink); text-align: center; }
  .preview-date-row button:first-child { border-color: var(--green); background: #e6ebe4; }
  .preview-time-row span { min-height: 46px; font-size: .8rem; }
  .preview-tour-card > small, .preview-summary-card > small { display: block; margin-top: 17px; color: var(--muted); font-size: .7rem; }
  .preview-summary-head { display: flex; justify-content: space-between; gap: 15px; align-items: start; padding-bottom: 15px; border-bottom: 1px solid var(--border); }
  .preview-summary-head span { color: var(--muted); font-size: .72rem; text-transform: uppercase; letter-spacing: .08em; }
  .preview-summary-card ul { margin: 18px 0 0; padding: 0; list-style: none; }
  .preview-summary-card li { display: grid; grid-template-columns: 42px 1fr; gap: 12px; align-items: center; padding: 12px 0; border-bottom: 1px solid var(--border); }
  .preview-summary-card li b { width: 38px; height: 38px; display: grid; place-items: center; border-radius: 12px; background: #e6ebe4; }
  .preview-summary-card li span { font-size: .84rem; }
  .preview-summary-card li.review b { background: #f5dfd2; color: var(--copper-dark); }
  .preview-handoff-grid, .preview-final-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px,7vw,82px); align-items: center; }
  .preview-handoff-card { padding: 26px; border: 1px solid rgba(192,113,75,.35); border-radius: var(--radius); background: #fff8f2; box-shadow: var(--shadow); }
  .preview-handoff-card > span { display: inline-flex; padding: 6px 9px; border-radius: 8px; background: #f5dfd2; color: var(--copper-dark); font-size: .7rem; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; }
  .preview-handoff-card h3 { margin: 20px 0; }
  .preview-handoff-card p { margin-bottom: 8px; }
  .preview-metrics { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; }
  .preview-metrics article { padding: 22px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--white); }
  .preview-metrics strong, .preview-metrics span { display: block; }
  .preview-metrics span { margin-top: 10px; color: var(--muted); font-size: .82rem; }
  .preview-final { background: linear-gradient(135deg,var(--cream),#eef1eb); }
  .preview-final p { max-width: 58ch; color: var(--muted); }
  .preview-price-card { padding: 28px; border-radius: var(--radius); background: var(--ink); color: var(--cream); box-shadow: var(--shadow); }
  .preview-price-card > span, .preview-price-card > strong, .preview-price-card > small { display: block; }
  .preview-price-card > span { color: #edb190; font-size: .75rem; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; }
  .preview-price-card > strong { margin-top: 18px; font-size: 3.5rem; line-height: 1; }
  .preview-price-card > small { color: #dce4de; }
  .preview-price-card hr { margin: 24px 0; border: 0; border-top: 1px solid rgba(255,255,255,.15); }
  .preview-price-card p { margin: 0; color: var(--cream); }
  .preview-verdict-grid { display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-top:42px; }
  .preview-verdict { position:relative; min-height:355px; padding:clamp(25px,4vw,42px); overflow:hidden; border:1px solid var(--border); border-radius:26px; }
  .preview-verdict > span { display:inline-flex; padding:7px 10px; border-radius:999px; font-size:.69rem; font-weight:850; letter-spacing:.09em; text-transform:uppercase; }
  .preview-verdict h2 { max-width:12ch; margin:26px 0 13px; font-size:clamp(2.1rem,4vw,4.1rem); line-height:.96; letter-spacing:-.04em; }
  .preview-verdict > p { max-width:52ch; margin:0 0 30px; font-size:.9rem; line-height:1.6; }
  .preview-verdict.problem { background:#fff1e9; }
  .preview-verdict.problem > span { background:#f2cab5; color:#8d4027; }
  .preview-verdict.problem > p { color:#744c3d; }
  .preview-verdict.solution { background:var(--ink); color:var(--cream); }
  .preview-verdict.solution > span { background:rgba(237,177,144,.18); color:#ffc9aa; }
  .preview-verdict.solution > p { color:#dce4de; }
  .preview-verdict.solution > img { position:absolute; top:20px; right:20px; width:96px; max-height:110px; object-fit:contain; filter:drop-shadow(0 15px 18px rgba(0,0,0,.18)); }
  .preview-chain { display:flex; align-items:center; gap:8px; padding:13px; border-radius:14px; font-size:.68rem; }
  .preview-chain b,.preview-chain strong { padding:8px 9px; border-radius:9px; text-align:center; }
  .preview-chain i { font-style:normal; font-size:1.15rem; }
  .preview-chain.danger { background:rgba(192,82,51,.08); }
  .preview-chain.danger b { background:white; }
  .preview-chain.danger strong { background:#b95032; color:white; }
  .preview-chain.gain { background:rgba(255,255,255,.08); }
  .preview-chain.gain b { background:rgba(255,255,255,.1); }
  .preview-chain.gain strong { background:#b7d2bd; color:var(--ink); }
  .preview-observation { margin-top:18px; padding:18px 22px; display:grid; grid-template-columns:220px 1fr; gap:24px; align-items:center; border:1px solid var(--border); border-left:6px solid var(--copper); border-radius:14px; background:rgba(255,253,248,.78); }
  .preview-observation span { color:var(--copper-dark); font-size:.68rem; font-weight:850; letter-spacing:.08em; text-transform:uppercase; }
  .preview-observation p { margin:0; font:650 1.02rem/1.5 'Newsreader Variable',serif; }
  .preview-comparison { background:var(--white); }
  .preview-section-head { display:flex; justify-content:space-between; gap:40px; align-items:end; margin-bottom:34px; }
  .preview-section-head h2 { max-width:16ch; margin:0; font-size:clamp(2.4rem,5vw,4.9rem); line-height:.96; }
  .preview-section-head > p { max-width:28ch; margin:0; color:var(--muted); font:650 1.2rem/1.35 'Newsreader Variable',serif; }
  .preview-lanes { display:grid; grid-template-columns:1fr 70px 1fr; gap:0; align-items:center; }
  .preview-lane { padding:25px; border:1px solid var(--border); border-radius:24px; }
  .preview-lane.current { background:#fff1e9; }
  .preview-lane.quid { background:#e5efe6; }
  .preview-lane header { display:flex; justify-content:space-between; gap:15px; padding-bottom:18px; border-bottom:1px solid var(--border); }
  .preview-lane header span { font-size:.72rem; font-weight:850; letter-spacing:.08em; text-transform:uppercase; }
  .preview-lane.current header span { color:#9c4b31; }
  .preview-lane.quid header span { color:#315f49; }
  .preview-lane header strong { font-size:.72rem; }
  .preview-lane > div { min-height:58px; display:grid; grid-template-columns:34px 1fr; gap:12px; align-items:center; padding:10px 0; }
  .preview-lane > div b { width:32px; height:32px; display:grid; place-items:center; border-radius:10px; background:white; font-size:.68rem; }
  .preview-lane > div span { font-size:.82rem; }
  .preview-lane > i { display:block; margin:-5px 0 -5px 15px; color:var(--muted); font-style:normal; }
  .preview-lane footer { margin-top:14px; padding:14px; border-radius:12px; font-weight:850; text-align:center; }
  .preview-lane.current footer { background:#b95032; color:white; }
