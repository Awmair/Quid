---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import PhotoPanel from '../../components/PhotoPanel.astro';
import QuickScan from '../../components/QuickScan.astro';
import { site } from '../../data/site';
import { resourceMedia } from '../../data/resourceMedia';
import { resourceFaqs } from '../../data/resourceFaqs';
import { pricing } from '../../data/pricing';

export async function getStaticPaths() {
  const entries = await getCollection('resources');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry, entries } }));
}
const { entry, entries } = Astro.props;
const { Content, headings } = await render(entry);
const related = entries
  .filter((item: typeof entry) => item.id !== entry.id)
  .sort((a: typeof entry,b: typeof entry) => a.data.order - b.data.order);
const isSoftwareGuide = entry.id === 'senior-living-admissions-automation-software';
const isFieldAudit = entry.id === 'senior-living-inquiry-to-tour-audit';
const url = `${site.domain}/resources/${entry.id}/`;
const media = resourceMedia[entry.id as keyof typeof resourceMedia];
const pageImage = media?.image.src;
const articleImage = pageImage ? new URL(pageImage, site.domain).toString() : `${site.domain}/quid-og.png`;
const visuals = {
  'how-to-increase-assisted-living-occupancy': {
    ...resourceMedia['how-to-increase-assisted-living-occupancy'],
    answer: 'Increase assisted living occupancy by improving the measurable path from existing inquiry to tour, assessment and move-in. Begin with prompt acknowledgement, easy tour scheduling, clear ownership, consistent follow-up and a daily view of stalled work before buying more leads.',
    items: [{kicker:'Measure',title:'Inquiry to tour'},{kicker:'Remove',title:'Scheduling friction'},{kicker:'Review',title:'What is stuck'}],
  },
  'senior-living-admissions-automation': {
    ...resourceMedia['senior-living-admissions-automation'],
    answer: 'Automate predictable coordination such as acknowledgements, tour options, reminders, and summaries. Keep clinical judgment, eligibility, sensitive conversations, and admissions authority with staff.',
    items: [{kicker:'Automate',title:'Routine coordination'},{kicker:'Keep human',title:'Judgment and empathy'},{kicker:'Design first',title:'A visible handoff'}],
  },
  'senior-living-inquiry-response-time': {
    ...resourceMedia['senior-living-inquiry-response-time'],
    answer: 'A senior living community should acknowledge a new website inquiry promptly, ideally through a controlled workflow that confirms receipt and offers a clear next step. The thoughtful human response may follow separately, especially when clinical, eligibility, pricing, or sensitive family questions are involved.',
    items: [{kicker:'First',title:'Acknowledge'},{kicker:'Then',title:'Offer a next step'},{kicker:'Always',title:'Show ownership'}],
  },
  'senior-living-inquiry-to-tour-audit': {
    ...resourceMedia['senior-living-inquiry-to-tour-audit'],
    answer: 'Quid reviewed 100 public senior living community website journeys across 28 operator groups and 23 states. Sixty-two pages exposed a manual or delayed-coordination signal, 47 exposed automation, and 14 showed both. This is a purposive, operator-clustered benchmark—not a randomized national prevalence study.',
    items: [{kicker:'Reviewed',title:'100 community pages'},{kicker:'Represented',title:'28 operator groups'},{kicker:'Published',title:'Data, sources and methodology'}],
  },
  'senior-living-tour-follow-up': {
    ...resourceMedia['senior-living-tour-follow-up'],
    answer: 'Confirm the visit clearly, let staff record the outcome, use limited approved follow-up, and pause as soon as a family replies or needs a real person.',
    items: [{kicker:'Before',title:'Confirm the tour'},{kicker:'After',title:'Record the outcome'},{kicker:'When needed',title:'Pause for staff'}],
  },
  'senior-living-daily-admissions-summary': {
    ...resourceMedia['senior-living-daily-admissions-summary'],
    answer: 'A daily admissions summary is a short operational view of new inquiries, tours today, overdue replies, human handoffs, stalled inquiries, staff tasks, and workflow failures. It helps the team start with exceptions instead of searching through inboxes and spreadsheets.',
    items: [{kicker:'Start',title:'New and due today'},{kicker:'Spot',title:'Stuck and overdue'},{kicker:'Assign',title:'Clear staff owners'}],
  },
  'senior-living-human-handoff-checklist': {
    ...resourceMedia['senior-living-human-handoff-checklist'],
    answer: 'A human handoff checklist defines what automation must not answer, the acknowledgement a family receives, who owns the question, how routine messages pause, and how the team tracks the issue until a staff member resolves it.',
    items: [{kicker:'Detect',title:'Out-of-scope questions'},{kicker:'Route',title:'Named staff owner'},{kicker:'Track',title:'Until resolved'}],
  },
  'senior-living-follow-up-templates': {
    ...resourceMedia['senior-living-follow-up-templates'],
    answer: 'Senior living follow-up templates give staff an approved starting point for inquiry acknowledgement, tour options, confirmation, reminders, post-tour thanks, stalled inquiries, and staff handoffs. Each template should match the community voice and stop when a person needs to respond.',
    items: [{kicker:'Respond',title:'Approved first reply'},{kicker:'Coordinate',title:'Tour messages'},{kicker:'Pause',title:'When staff takes over'}],
  },
  'senior-living-admissions-automation-software': {
    ...resourceMedia['senior-living-admissions-automation-software'],
    answer: 'There is no single best platform for every senior living operator. Complete CRMs fit broad system-of-record needs; AI sales platforms fit multi-channel engagement; and focused automation fits a defined inquiry-to-tour workflow around current tools. This guide compares public positioning and feature information, not hands-on testing of every platform.',
    items: [{kicker:'Complete CRM',title:'System of record'},{kicker:'AI platform',title:'Multi-channel growth'},{kicker:'Focused workflow',title:'Start with one process'}],
  },
} as const;
const visual = visuals[entry.id as keyof typeof visuals];
const faqs = resourceFaqs[entry.id as keyof typeof resourceFaqs];
const schema = [
  {'@context':'https://schema.org','@type':'Article',headline:entry.data.title,description:entry.data.description,image:articleImage,author:{'@type':'Organization',name:entry.data.author,url:site.domain},publisher:{'@type':'Organization',name:'Quid',url:site.domain},datePublished:entry.data.publishedDate.toISOString(),dateModified:entry.data.updatedDate.toISOString(),mainEntityOfPage:url,url},
  {'@context':'https://schema.org','@type':'BreadcrumbList',itemListElement:[
    {'@type':'ListItem',position:1,name:'Home',item:site.domain},
    {'@type':'ListItem',position:2,name:'Resources',item:`${site.domain}/resources/`},
    {'@type':'ListItem',position:3,name:entry.data.title,item:url},
  ]},
  ...(faqs ? [{'@context':'https://schema.org','@type':'FAQPage','mainEntity':faqs.map(([question,answer]) => ({'@type':'Question',name:question,acceptedAnswer:{'@type':'Answer',text:answer}}))}] : []),
  ...(isSoftwareGuide ? [{'@context':'https://schema.org','@type':'ItemList',name:'Senior living admissions automation software options',description:'An unranked list of six options compared using current official vendor information.',numberOfItems:6,itemListOrder:'https://schema.org/ItemListUnordered',itemListElement:[
    ['Quid','https://get-quid.site/'],['Further','https://www.talkfurther.com/'],['Aline Connect','https://alineops.com/senior-living/sales-software/'],['ECP CRM','https://www.ecp123.com/crm'],['WelcomeHome','https://www.welcomehomesoftware.com/senior-living-crm'],['Advantage Anywhere','https://advantageanywhere.com/senior-living-and-care/'],
  ].map(([name,item],index) => ({'@type':'ListItem',position:index+1,name,item}))}] : []),
  ...(isFieldAudit ? [{'@context':'https://schema.org','@type':'Dataset',name:'2026 Senior Living Inquiry-to-Tour Benchmark',description:'A purposive, operator-clustered benchmark of 100 public senior living community inquiry and tour website journeys across 28 operator groups and 23 US states, reviewed July 12–14, 2026.',url,creator:{'@type':'Organization',name:'Quid Research',url:site.domain},datePublished:'2026-07-13',dateModified:'2026-07-14',temporalCoverage:'2026-07-12/2026-07-14',spatialCoverage:{'@type':'Place',name:'United States'},measurementTechnique:'Manual review of public community pages and visible inquiry or tour controls without form submission.',variableMeasured:['Primary inquiry call to action','Visible journey category','Manual or delayed coordination signal','Visible automation signal','Operator-size band','Operator cluster','US state'],distribution:[
    {'@type':'DataDownload',name:'100-row anonymized benchmark dataset',encodingFormat:'text/csv',contentUrl:`${site.domain}/data/senior-living-inquiry-to-tour-audit-2026.csv`},
    {'@type':'DataDownload',name:'75-page named expansion source register',encodingFormat:'text/csv',contentUrl:`${site.domain}/data/senior-living-inquiry-to-tour-benchmark-sources-2026.csv`},
    {'@type':'DataDownload',name:'Four-page benchmark report',encodingFormat:'application/pdf',contentUrl:`${site.domain}/downloads/quid-senior-living-inquiry-to-tour-benchmark-2026.pdf`},
  ]}] : []),
];
---
<BaseLayout title={entry.data.seoTitle || `${entry.data.title} | Quid`} description={entry.data.description} image={pageImage} canonicalUrl={url} schema={schema}>
  <Breadcrumbs items={[{label:'Home',href:'/'},{label:'Resources',href:'/resources/'},{label:entry.data.title}]} />
  <header class="page-hero"><div class="shell page-hero-grid"><div><p class="eyebrow">{isSoftwareGuide ? '2026 buyer’s guide' : isFieldAudit ? 'Original field research · July 2026' : 'Quid practical guide'}</p><h1>{entry.data.title}</h1><p class="lede">{entry.data.description}</p><p class="resource-meta"><span>By {entry.data.author}</span><span>Published {entry.data.publishedDate.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}</span><span>Updated {entry.data.updatedDate.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}</span></p></div>{visual && <PhotoPanel image={visual.image} alt={visual.alt} priority />}</div></header>
  {visual && <section class="section-sm section-sand"><div class="shell"><QuickScan items={[...visual.items]} label="Guide at a glance" /></div></section>}
  <section class="section section-white"><div class="shell article-shell"><aside class="toc" aria-label="Table of contents"><h2>In this guide</h2>{headings.filter((h: {depth:number}) => h.depth === 2).map((h: {slug:string;text:string}) => <a href={`#${h.slug}`}>{h.text}</a>)}{faqs && <a href="#frequently-asked-questions">Frequently asked questions</a>}</aside><article class={`prose ${isSoftwareGuide ? 'buyer-guide' : ''}`}>{visual && <div class="article-quick-answer"><strong>Direct answer</strong><p>{visual.answer}</p></div>}<Content />{faqs && <section class="article-faq" aria-labelledby="frequently-asked-questions"><h2 id="frequently-asked-questions">Frequently asked questions</h2><div class="faq-list">{faqs.map(([question,answer]) => <details><summary>{question}</summary><p>{answer}</p></details>)}</div></section>}{isSoftwareGuide ? <div class="notice-card resource-next-step buyer-final-cta"><p class="eyebrow">A controlled first step</p><h2>Need a focused starting point instead of a platform migration?</h2><p>Quid begins with one community, one website inquiry source and one tour calendar. The 30-day pilot measures how the workflow performs before any continuation decision.</p><div class="buyer-price"><span>30-Day Quid Admissions Pilot</span><strong>$1,000 one-time</strong><small>Keep Quid for $899/month per community after the pilot.</small></div><div class="button-row"><a class="button" href="/pilot/">Explore the 30-Day Pilot</a><a class="button button-secondary" href="/meet-quid/">Meet Quid</a></div><p class="buyer-vendor-links">Compare directly: <a href="https://www.talkfurther.com/" target="_blank" rel="noopener noreferrer">Further</a>, <a href="https://alineops.com/senior-living/sales-software/" target="_blank" rel="noopener noreferrer">Aline</a>, <a href="https://www.ecp123.com/crm" target="_blank" rel="noopener noreferrer">ECP</a>, <a href="https://www.welcomehomesoftware.com/senior-living-crm" target="_blank" rel="noopener noreferrer">WelcomeHome</a>, and <a href="https://advantageanywhere.com/senior-living-and-care/" target="_blank" rel="noopener noreferrer">Advantage Anywhere</a>.</p></div> : <div class="notice-card resource-next-step">{entry.id === 'senior-living-inquiry-response-time' ? <><h2>Apply the workflow to one community.</h2><p>See how Quid can apply this workflow to one community, one inquiry source and one tour calendar.</p><p class="resource-pricing-line"><strong>30-day pilot: {pricing.pilot.displayWithBilling}.</strong> Continuation: {pricing.ongoing.monthlyDisplay} after the pilot.</p><div class="button-row"><a class="button" href="/pilot/">Review the 30-day pilot</a><a class="button button-secondary" href="/meet-quid/">Meet Quid</a></div></> : <><h2>Choose the next practical step.</h2><p>See how Quid presents admissions activity, review the managed pilot, or request a walkthrough around your current workflow.</p><div class="button-row"><a class="button" href="/see-quid-in-action/">See the Quid admissions dashboard</a><a class="button button-secondary" href="/pilot/">Review the 30-day admissions pilot</a><a class="button button-secondary" href="/meet-quid/">Request a Quid walkthrough</a></div><p><a href="#follow-up-fix-kit">Get the Senior Living Follow-Up Fix Kit</a> for templates, a daily tracker, and a human-handoff checklist.</p></>}</div>}</article></div></section>
  <section class="section section-sand"><div class="shell"><h2>Related senior living admissions guides</h2><div class="card-grid three">{related.slice(0,3).map((item: typeof entry) => <article class="card"><h3>{item.data.title}</h3><p>{item.data.description}</p><a href={`/resources/${item.id}/`}>Read {item.data.title}</a></article>)}</div></div></section>
</BaseLayout>
