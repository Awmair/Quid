---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Mascot from '../../components/Mascot.astro';
import QuickScan from '../../components/QuickScan.astro';
import AnswerBlock from '../../components/AnswerBlock.astro';
import { site } from '../../data/site';
import { resourceMedia } from '../../data/resourceMedia';
const resources = (await getCollection('resources')).sort((a,b) => a.data.order - b.data.order);
const schema = [
  {'@context':'https://schema.org','@type':'CollectionPage',name:'Quid Senior Living Admissions Resources',url:`${site.domain}/resources`,description:'Practical guides for senior living admissions teams.'},
  {'@context':'https://schema.org','@type':'BreadcrumbList',itemListElement:[
    {'@type':'ListItem',position:1,name:'Home',item:site.domain},
    {'@type':'ListItem',position:2,name:'Resources',item:`${site.domain}/resources`},
  ]},
];
---
<BaseLayout title="Senior Living Admissions Resources | Quid" description="Practical guides on senior living inquiry response, tour coordination, follow-up, human handoffs, and responsible admissions automation." schema={schema}>
  <Breadcrumbs items={[{label:'Home',href:'/'},{label:'Resources'}]} />
  <section class="page-hero"><div class="shell page-hero-grid"><div><p class="eyebrow">Resource center</p><h1>Practical guides for senior living admissions teams.</h1><p class="lede">Clear guidance on inquiry response, tour coordination, follow-up, human handoffs, and responsible admissions automation.</p><AnswerBlock answer="Quid’s resource center gives senior living teams practical guides for inquiry response, tour follow-up, human handoffs, and admissions workflow improvement." /></div><Mascot pose="summary" class="page-mascot" alt="Quid thoughtfully reviewing a practical admissions guide" width={340} /></div></section>
  <section class="section-sm section-sand"><div class="shell"><QuickScan items={[{kicker:'Decide',title:'What stays human',text:'Draw clear boundaries before adding automation.'},{kicker:'Respond',title:'Make the next step easy',text:'Acknowledge quickly without demanding constant inbox monitoring.'},{kicker:'Follow up',title:'Keep tours moving',text:'Use clear states, ownership, and approved messages.'}]} label="Resource topics at a glance" /></div></section>
  <section class="section-sm section-white"><div class="shell"><article class="comparison-hub-promo"><div><p class="eyebrow">2026 buyer’s hub</p><h2>Compare Senior Living Software</h2><p>Compare Aline, Further, ECP, WelcomeHome, Advantage Anywhere and Quid using current product information, pricing visibility and best-fit scenarios.</p></div><a class="button" href="/resources/senior-living-software-comparisons/">Explore Comparisons</a></article></div></section>
  <section class="section section-white"><div class="shell card-grid three">{resources.map((entry) => { const media = resourceMedia[entry.id as keyof typeof resourceMedia]; return <article class="card resource-card">{media && <Image class="resource-thumb" src={media.image} alt={media.alt} widths={[360,540,720]} sizes="(max-width:760px) 100vw, 33vw" format="webp" loading="lazy" />}<p class="eyebrow">Guide</p><h2 style="font-size:2rem">{entry.data.title}</h2><p>{entry.data.description}</p><p class="resource-meta"><span>By {entry.data.author}</span><span>Updated {entry.data.updatedDate.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}</span></p><a class="button button-secondary" href={`/resources/${entry.id}`}>Read the guide</a></article>})}</div></section>
  <section class="section section-sage"><div class="narrow center"><h2>Better follow-up begins with a process your team can see.</h2><p class="lede center">Use these guides to decide what should move consistently, what should remain human, and how to review the workflow without adding more chaos.</p><a class="button" href="/meet-quid">Meet Quid</a></div></section>
</BaseLayout>
