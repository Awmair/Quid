---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Mascot from '../../components/Mascot.astro';
import QuickScan from '../../components/QuickScan.astro';
import AnswerBlock from '../../components/AnswerBlock.astro';
import { site } from '../../data/site';
import { resourceMedia } from '../../data/resourceMedia';
const resources = (await getCollection('resources')).sort((a,b) => a.data.order - b.data.order);
const hubItems = [
  ...resources.map((entry) => ({ name: entry.data.title, url: `${site.domain}/resources/${entry.id}/` })),
  { name: 'Senior Living Website Inquiry-Flow Grader', url: `${site.domain}/senior-living-inquiry-flow-grader/` },
  { name: 'Senior Living Software Comparisons', url: `${site.domain}/resources/senior-living-software-comparisons/` },
];
const intentClusters = [
  {
    title: 'Research and benchmarks',
    description: 'Use source-led evidence to examine inquiry friction before changing the workflow.',
    links: [
      { label: '100-community inquiry-to-tour benchmark', href: '/resources/senior-living-inquiry-to-tour-audit/' },
      { label: 'Inquiry response-time guide', href: '/resources/senior-living-inquiry-response-time/' },
      { label: 'Assisted living occupancy guide', href: '/resources/how-to-increase-assisted-living-occupancy/' },
    ],
  },
  {
    title: 'Lead and inquiry follow-up',
    description: 'Build a prompt, approved path from new website inquiry to a clear next step.',
    links: [
      { label: 'Lead follow-up software guide', href: '/resources/best-assisted-living-lead-follow-up-software/' },
      { label: 'Follow-up email templates', href: '/resources/senior-living-follow-up-templates/' },
      { label: 'Daily inquiry and tour summary', href: '/resources/senior-living-daily-admissions-summary/' },
    ],
  },
  {
    title: 'Tours and human handoffs',
    description: 'Coordinate booked visits while keeping sensitive questions and decisions with staff.',
    links: [
      { label: 'Tour scheduling tools guide', href: '/resources/best-senior-living-tour-scheduling-tools-website-inquiries/' },
      { label: 'Tour follow-up framework', href: '/resources/senior-living-tour-follow-up/' },
      { label: 'Human handoff checklist', href: '/resources/senior-living-human-handoff-checklist/' },
    ],
  },
  {
    title: 'Software buying decisions',
    description: 'Separate CRM replacement, broader engagement and focused inquiry-to-tour automation.',
    links: [
      { label: 'Ranked software guide', href: '/resources/senior-living-admissions-automation-software/' },
      { label: 'Vendor comparison hub', href: '/resources/senior-living-software-comparisons/' },
      { label: 'CRM alternatives guide', href: '/resources/best-senior-living-crm-alternatives-focused-workflow/' },
    ],
  },
] as const;
const schema = [
  {'@context':'https://schema.org','@type':'CollectionPage',name:'Quid Senior Living Admissions Resources',url:`${site.domain}/resources/`,description:'Practical guides for senior living inquiry follow-up, tour scheduling and human handoffs.',mainEntity:{'@type':'ItemList',numberOfItems:hubItems.length,itemListOrder:'https://schema.org/ItemListOrderAscending',itemListElement:hubItems.map((item,index)=>({'@type':'ListItem',position:index+1,item:{'@type':'WebPage',name:item.name,url:item.url}}))}},
  {'@context':'https://schema.org','@type':'BreadcrumbList',itemListElement:[
    {'@type':'ListItem',position:1,name:'Home',item:site.domain},
    {'@type':'ListItem',position:2,name:'Resources',item:`${site.domain}/resources/`},
  ]},
];
---
<BaseLayout title="Senior Living Admissions Resources | Quid" description="Practical guides for fewer missed senior living inquiries, more booked tours, consistent follow-up, and clear human handoffs." schema={schema}>
  <Breadcrumbs items={[{label:'Home',href:'/'},{label:'Resources'}]} />
  <section class="page-hero"><div class="shell page-hero-grid"><div><p class="eyebrow">Resource center</p><h1>Practical ways to miss fewer inquiries and book more tours.</h1><p class="lede">Clear guidance on inquiry response, tour coordination, background follow-up, human handoffs, and giving staff more time for residents and families.</p><AnswerBlock answer="Quid’s resource center gives senior living teams practical guides for reducing missed inquiries, improving tour follow-up, keeping human handoffs clear, and removing avoidable admin work." /></div><Mascot pose="summary" class="page-mascot" alt="Quid thoughtfully reviewing a practical admissions guide" width={340} /></div></section>
  <section class="section-sm section-sand"><div class="shell"><QuickScan items={[{kicker:'Decide',title:'What stays human',text:'Draw clear boundaries before adding automation.'},{kicker:'Respond',title:'Make the next step easy',text:'Acknowledge quickly without demanding constant inbox monitoring.'},{kicker:'Follow up',title:'Keep tours moving',text:'Use clear states, ownership, and approved messages.'}]} label="Resource topics at a glance" /></div></section>
  <section class="section-sm section-white"><div class="shell"><article class="comparison-hub-promo"><div><p class="eyebrow">Free two-minute self-assessment</p><h2>Grade the path after “Request a Tour.”</h2><p>Check eight visible inquiry, acknowledgement, tour scheduling, ownership and human-handoff signals without submitting a form or sharing resident data.</p></div><a class="button" href="/senior-living-inquiry-flow-grader/">Grade My Website Flow</a></article></div></section>
  <section class="section section-sand"><div class="shell"><div class="section-heading"><div><p class="eyebrow">Choose by intent</p><h2>Start with the question you need to answer.</h2></div><p>Research, operating guides and software comparisons serve different decisions.</p></div><div class="card-grid three">{intentClusters.map((cluster)=><article class="card"><h3>{cluster.title}</h3><p>{cluster.description}</p><ul>{cluster.links.map((link)=><li><a href={link.href}>{link.label}</a></li>)}</ul></article>)}</div></div></section>
  <section class="section-sm section-white"><div class="shell"><article class="comparison-hub-promo"><div><p class="eyebrow">2026 buyer’s hub</p><h2>Compare Senior Living Software</h2><p>Compare Quid, Further, Aline, ECP, WelcomeHome, Yardi and Advantage Anywhere using current product information, pricing visibility and best-fit scenarios.</p></div><div class="button-row"><a class="button" href="/resources/senior-living-admissions-automation-software/">See the Ranked List</a><a class="button button-secondary" href="/resources/senior-living-software-comparisons/">Open the Comparison Hub</a></div></article></div></section>
  <section class="section section-white"><div class="shell card-grid three">{resources.map((entry) => { const media = resourceMedia[entry.id as keyof typeof resourceMedia]; return <article class="card resource-card">{media && <Image class="resource-thumb" src={media.image} alt={media.alt} widths={[360,540,720]} sizes="(max-width:760px) 100vw, 33vw" format="webp" loading="lazy" />}<p class="eyebrow">Guide</p><h2 class="resource-card-title">{entry.data.title}</h2><p>{entry.data.description}</p><p class="resource-meta"><span>By {entry.data.author}</span><span>Updated {entry.data.updatedDate.toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}</span></p><a class="button button-secondary" href={`/resources/${entry.id}/`}>Read the guide</a></article>})}</div></section>
  <section class="section section-sage"><div class="narrow center"><h2>Better follow-up should not mean another tool to manage.</h2><p class="lede center">Use these guides to decide what should move behind the scenes, what should remain human, and how to give staff more time for residents and families.</p><a class="button" href="/meet-quid/">See How Quid Fits</a></div></section>
</BaseLayout>
