---
import '../styles/global.css';
import { Image } from 'astro:assets';
import wordmark from '../assets/brand/quid-wordmark.svg';

const title = 'Private Inquiry-to-Tour Kit | Quid';
const description = 'A private inquiry-to-tour plan showing what Quid could handle behind the scenes for one senior living community.';
const canonical = 'https://get-quid.site/private-kit/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="noindex,nofollow,noarchive,nosnippet" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Quid" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://get-quid.site/quid-og.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://get-quid.site/quid-og.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body class="kit-body">
    <header class="kit-header">
      <div class="kit-header-inner">
        <a href="/" aria-label="Quid home"><Image src={wordmark} alt="Quid" width={112} /></a>
        <div class="kit-header-meta">
          <span>Private · prepared for <b data-community>your community</b></span>
          <button class="kit-print" type="button" data-print>Print / Save PDF</button>
        </div>
      </div>
    </header>

    <main class="kit-layout" data-kit hidden>
      <aside class="kit-sidebar" aria-label="Kit chapters">
        <div>
          <p class="kit-kicker">Inquiry-to-tour kit</p>
          <strong data-community>Your community</strong>
          <span data-location>United States</span>
        </div>
        <nav>
          <button class="is-active" type="button" data-go="0"><i>01</i><span>Audit &amp; diagnosis</span></button>
          <button type="button" data-go="1"><i>02</i><span>Recommended workflow</span></button>
          <button type="button" data-go="2"><i>03</i><span>Ready-to-use templates</span></button>
          <button type="button" data-go="3"><i>04</i><span>Tracker &amp; action plan</span></button>
        </nav>
        <small>Prepared from public business information. No inquiry form was submitted.</small>
      </aside>

      <section class="kit-stage">
        <article class="kit-page kit-cover-page is-active" data-page="0">
          <div class="kit-page-topline"><span>01 / 04</span><span data-prepared-date>Prepared privately by Quid</span></div>
          <div class="kit-cover-grid">
            <div>
              <p class="kit-eyebrow">Private inquiry-to-tour kit for</p>
              <h1 data-community>Your community</h1>
              <p class="kit-lede">Fewer missed inquiries. More booked tours. No extra admin hire.</p>
              <div class="kit-pills"><span data-location>United States</span><a data-website href="#" target="_blank" rel="noopener noreferrer">Website reviewed</a></div>
            </div>
            <div class="kit-score" aria-label="Public journey audit score">
              <div><strong data-audit-score>—</strong><span>/100</span></div>
              <b data-audit-label>Public journey audit</b>
              <small>Based only on what a family can see online</small>
            </div>
          </div>

          <div class="kit-commercial-grid">
            <article class="kit-commercial problem"><span>The admin gap</span><h2>Routine follow-up waits when staff are busy with people.</h2><div><b>Inquiry</b><i>→</i><b>Wait</b><i>→</i><strong>Tour opportunity missed</strong></div></article>
            <article class="kit-commercial solution"><span>The Quid fit</span><h2>Background work moves without another daily tool.</h2><div><b>Inquiry</b><i>→</i><b>Fast next step</b><i>→</i><strong>More booked tours</strong></div></article>
          </div>

          <section class="kit-observation">
            <div><span>Public website observation</span><b data-cta>Request a Tour</b></div>
            <p data-observation>The public website captures interest, but the next step appears to depend on manual staff follow-up.</p>
          </section>

          <section class="kit-included">
            <div class="kit-section-heading"><div><p class="kit-eyebrow">Included in this private plan</p><h2>Six parts Quid can help put behind the scenes.</h2></div><p>Built around the public inquiry path we reviewed.</p></div>
            <div class="kit-included-grid">
              <span>✓ Inquiry response templates</span>
              <span>✓ Tour follow-up sequence</span>
              <span>✓ Stalled-lead reactivation template</span>
              <span>✓ Daily “what’s stuck?” tracker</span>
              <span>✓ Human-handoff checklist</span>
              <span>✓ Simple admissions workflow map</span>
            </div>
          </section>

          <section class="kit-audit-section">
            <div class="kit-section-heading"><div><p class="kit-eyebrow">Public journey audit</p><h2>What a family sees</h2></div></div>
            <div class="kit-audit-grid" data-audit-list></div>
          </section>
        </article>

        <article class="kit-page" data-page="1">
          <div class="kit-page-topline"><span>02 / 04</span><span data-community>Your community</span></div>
          <p class="kit-eyebrow">Simple admissions workflow map</p>
          <h2>See the manual gap—and the fix.</h2>
          <p class="kit-page-intro">Same inquiry. A faster, clearer route to a tour.</p>

          <div class="kit-compare">
            <article class="kit-compare-lane manual">
              <header><span>Your current path</span><strong>Manual</strong></header>
              <div><b>1</b><span><strong data-cta>Request a Tour</strong> submitted</span></div><i>↓</i>
              <div><b>2</b><span>Form waits in an inbox</span></div><i>↓</i>
              <div><b>3</b><span>Staff replies when available</span></div><i>↓</i>
              <div><b>4</b><span>Calendar back-and-forth</span></div>
              <footer>Risk: another community responds first</footer>
            </article>
            <div class="kit-vs">VS</div>
            <article class="kit-compare-lane automated">
              <header><span>The Quid path</span><strong>Immediate</strong></header>
              <div><b>1</b><span>Inquiry triggers approved workflow</span></div><i>↓</i>
              <div><b>2</b><span>Family receives a fast reply</span></div><i>↓</i>
              <div><b>3</b><span>Approved tour times appear</span></div><i>↓</i>
              <div><b>4</b><span>Follow-up runs; staff handles exceptions</span></div>
              <footer>Upside: more inquiries can reach tours</footer>
            </article>
          </div>

          <div class="kit-revenue-strip"><b>Existing demand</b><i>→</i><b>More responses</b><i>→</i><b>More tours</b><i>→</i><strong>More move-in opportunities</strong></div>

          <section class="kit-handoff">
            <div><span>Human-handoff checklist</span><h3>Quid handles routine coordination. People handle judgment.</h3><p>Pause the workflow and alert the right person when any of these appear.</p></div>
            <ul data-handoff-list></ul>
          </section>
        </article>

        <article class="kit-page" data-page="2">
          <div class="kit-page-topline"><span>03 / 04</span><span data-community>Your community</span></div>
          <p class="kit-eyebrow">Inquiry response templates</p>
          <h2>Copy your team can use today.</h2>
          <p class="kit-page-intro">Replace bracketed fields, approve the wording and use it manually or in a workflow.</p>

          <div class="kit-template-grid">
            <section class="kit-template featured">
              <div><span>Email · immediately</span><button type="button" data-copy="first-response">Copy</button></div>
              <pre data-first-response id="first-response"></pre>
            </section>
            <section class="kit-template">
              <div><span>SMS · immediately</span><button type="button" data-copy="sms-response">Copy</button></div>
              <pre data-sms-response id="sms-response"></pre>
            </section>
          </div>

          <section class="kit-followup-section">
            <div class="kit-section-heading"><div><p class="kit-eyebrow">Tour follow-up sequence</p><h2>Three useful nudges. Then stop.</h2></div><p>A reply stops the sequence. A sensitive question goes to a person.</p></div>
            <div class="kit-followups" data-followups></div>
          </section>

          <section class="kit-stalled">
            <div class="kit-stalled-heading"><div><p class="kit-eyebrow">Stalled-lead reactivation template</p><h2>Restart a quiet conversation.</h2></div><button type="button" data-copy="stalled-lead">Copy</button></div>
            <div class="kit-stalled-copy"><b data-stalled-subject></b><pre data-stalled-body id="stalled-lead"></pre></div>
          </section>
        </article>

        <article class="kit-page" data-page="3">
          <div class="kit-page-topline"><span>04 / 04</span><span data-community>Your community</span></div>
          <p class="kit-eyebrow">Daily “what’s stuck?” tracker</p>
          <h2>See what needs a person today.</h2>
          <p class="kit-page-intro">A short daily view keeps warm inquiries from disappearing into inboxes. The rows below are illustrative—never resident data.</p>

          <section class="kit-tracker" aria-label="Illustrative daily inquiry tracker">
            <div class="kit-tracker-head"><span>Priority</span><span>Inquiry</span><span>Status</span><span>Owner</span><span>Next action</span></div>
            <div data-stuck-tracker></div>
          </section>

          <div class="kit-section-heading kit-plan-heading"><div><p class="kit-eyebrow">30-day action plan</p><h2>Start narrow. Prove the handoff.</h2></div><p>One source, one calendar, one accountable owner.</p></div>

          <div class="kit-plan">
            <article><span>Week 1</span><h3>Map</h3><p>Approve the form, copy, calendar owner and handoff rules.</p></article>
            <article><span>Week 2</span><h3>Test</h3><p>Test standard, unanswered and human-review scenarios.</p></article>
            <article><span>Week 3</span><h3>Run</h3><p>Launch one source and review the tracker daily.</p></article>
            <article><span>Week 4</span><h3>Measure</h3><p>Review response speed, tours and correct handoffs.</p></article>
          </div>

          <section class="kit-final-cta">
            <div><p class="kit-eyebrow">Want to see this mapped to your actual process?</p><h2>See what Quid can take off your team’s plate.</h2><p>No platform migration. No extra daily tool for frontline staff. Just one useful background workflow and clear guardrails around it.</p></div>
            <a class="kit-cta" data-walkthrough href="mailto:charcopadart@gmail.com">See How Quid Fits</a>
          </section>

          <footer class="kit-disclaimer"><b>About this kit</b><p>This private concept was prepared from publicly available business information. It does not represent an active integration, endorsement, partnership, performance result or use of resident data. All live messages, timing rules and handoffs require community review and approval.</p></footer>
        </article>

        <div class="kit-controls">
          <button type="button" data-prev disabled>← Previous</button>
          <span><b data-current>1</b> of 4</span>
          <button type="button" data-next>Next →</button>
        </div>
      </section>
    </main>

    <section class="kit-loading" data-loading>
      <Image src={wordmark} alt="Quid" width={140} />
      <p>Preparing your private kit…</p>
    </section>
    <section class="kit-invalid" data-invalid hidden>
      <Image src={wordmark} alt="Quid" width={140} />
      <h2>This kit link is incomplete.</h2>
      <p>Please reply to Umair and ask for a fresh private link.</p>
    </section>

    <script is:inline>
      (() => {
        const cleanSlug = (value) => (value || '').toLowerCase().replace(/[^a-z0-9-]/g, '').slice(0, 80);
        const clean = (value, max = 500) => String(value || '').replace(/[<>\u0000-\u001F]/g, '').trim().slice(0, max);
        const slug = cleanSlug(window.location.hash.replace(/^#/, ''));
        const kit = document.querySelector('[data-kit]');
        const loading = document.querySelector('[data-loading]');
        const invalid = document.querySelector('[data-invalid]');

        const fail = () => {
          loading?.setAttribute('hidden', '');
          kit?.setAttribute('hidden', '');
          invalid?.removeAttribute('hidden');
        };

        if (!slug) { fail(); return; }

        fetch(`/private-kits/${slug}.json`, { cache: 'no-store' })
          .then((response) => { if (!response.ok) throw new Error('Kit not found'); return response.json(); })
          .then((data) => {
            const community = clean(data.community, 100);
            if (!community) throw new Error('Community missing');
            const location = clean(data.location, 100) || 'United States';
            const cta = clean(data.cta, 60) || 'Request a Tour';
            const observation = clean(data.observation, 500) || 'The public website captures interest, but the next step appears to depend on manual staff follow-up.';
            const firstResponse = clean(data.firstResponse, 1800).replaceAll('Sample Senior Living Community', community);
            const smsResponse = clean(data.smsResponse, 600).replaceAll('Sample Senior Living Community', community);
            const stalledSubject = clean(data.stalledLead?.subject, 120) || 'Still looking?';
            const stalledBody = clean(data.stalledLead?.body, 1000).replaceAll('Sample Senior Living Community', community);

            document.querySelectorAll('[data-community]').forEach((node) => { node.textContent = community; });
            document.querySelectorAll('[data-location]').forEach((node) => { node.textContent = location; });
            document.querySelectorAll('[data-cta]').forEach((node) => { node.textContent = cta; });
            document.querySelectorAll('[data-observation]').forEach((node) => { node.textContent = observation; });
            document.querySelectorAll('[data-prepared-date]').forEach((node) => { node.textContent = clean(data.preparedDate, 50) || 'Prepared privately by Quid'; });
            document.querySelectorAll('[data-audit-score]').forEach((node) => { node.textContent = Number.isFinite(Number(data.auditScore)) ? String(Math.max(0, Math.min(100, Number(data.auditScore)))) : '—'; });
            document.querySelectorAll('[data-audit-label]').forEach((node) => { node.textContent = clean(data.auditLabel, 60) || 'Public journey audit'; });
            document.querySelectorAll('[data-first-response]').forEach((node) => { node.textContent = firstResponse; });
            document.querySelectorAll('[data-sms-response]').forEach((node) => { node.textContent = smsResponse; });
            document.querySelectorAll('[data-stalled-subject]').forEach((node) => { node.textContent = `Subject: ${stalledSubject}`; });
            document.querySelectorAll('[data-stalled-body]').forEach((node) => { node.textContent = stalledBody; });

            const websiteLink = document.querySelector('[data-website]');
            try {
              const url = new URL(clean(data.website, 260));
              if (!['http:', 'https:'].includes(url.protocol)) throw new Error('Invalid protocol');
              if (websiteLink instanceof HTMLAnchorElement) websiteLink.href = url.toString();
            } catch { websiteLink?.setAttribute('hidden', ''); }

            const auditList = document.querySelector('[data-audit-list]');
            if (auditList) {
              auditList.textContent = '';
              (Array.isArray(data.audit) ? data.audit : []).slice(0, 4).forEach((item, index) => {
                const card = document.createElement('article');
                card.className = `kit-audit-card tone-${clean(item.tone, 10) || 'watch'}`;
                const top = document.createElement('div');
                const number = document.createElement('span'); number.textContent = `0${index + 1}`;
                const status = document.createElement('b'); status.textContent = clean(item.status, 30) || 'Review';
                top.append(number, status);
                const heading = document.createElement('h3'); heading.textContent = clean(item.title, 80);
                const note = document.createElement('p'); note.textContent = clean(item.note, 240);
                card.append(top, heading, note); auditList.append(card);
              });
            }

            const followups = document.querySelector('[data-followups]');
            if (followups) {
              followups.textContent = '';
              (Array.isArray(data.followUps) ? data.followUps : []).slice(0, 3).forEach((item, index) => {
                const card = document.createElement('article');
                const when = document.createElement('span'); when.textContent = clean(item.when, 40);
                const heading = document.createElement('h3'); heading.textContent = clean(item.subject, 100);
                const body = document.createElement('p'); body.textContent = clean(item.body, 500).replaceAll('Sample Senior Living Community', community);
                const badge = document.createElement('b'); badge.textContent = `0${index + 1}`;
                card.append(badge, when, heading, body); followups.append(card);
              });
            }

            const handoffList = document.querySelector('[data-handoff-list]');
            if (handoffList) {
              handoffList.textContent = '';
              (Array.isArray(data.handoffChecklist) ? data.handoffChecklist : []).slice(0, 6).forEach((item) => {
                const row = document.createElement('li');
                row.textContent = clean(item, 160);
                handoffList.append(row);
              });
            }

            const stuckTracker = document.querySelector('[data-stuck-tracker]');
            if (stuckTracker) {
              stuckTracker.textContent = '';
              (Array.isArray(data.stuckTracker) ? data.stuckTracker : []).slice(0, 6).forEach((item) => {
                const row = document.createElement('div');
                row.className = 'kit-tracker-row';
                ['priority', 'item', 'status', 'owner', 'next'].forEach((key) => {
                  const cell = document.createElement('span');
                  cell.dataset.label = key === 'item' ? 'Inquiry' : key === 'next' ? 'Next action' : `${key.charAt(0).toUpperCase()}${key.slice(1)}`;
                  cell.textContent = clean(item[key], 160);
                  row.append(cell);
                });
                stuckTracker.append(row);
              });
            }

            const metrics = document.querySelector('[data-metrics]');
            if (metrics) {
              metrics.textContent = '';
              (Array.isArray(data.metrics) ? data.metrics : []).slice(0, 4).forEach((item) => {
                const card = document.createElement('article');
                const heading = document.createElement('strong'); heading.textContent = clean(item.name, 80);
                const detail = document.createElement('span'); detail.textContent = clean(item.detail, 200);
                card.append(heading, detail); metrics.append(card);
              });
            }

            const walkthrough = document.querySelector('[data-walkthrough]');
            if (walkthrough instanceof HTMLAnchorElement) {
              const subject = encodeURIComponent(`Quid kit walkthrough — ${community}`);
              const body = encodeURIComponent(`Hi Umair,\n\nI'd like to walk through the inquiry-to-tour kit for ${community}.\n\n`);
              walkthrough.href = `mailto:charcopadart@gmail.com?subject=${subject}&body=${body}`;
            }

            document.title = `${community} — Private Inquiry-to-Tour Kit`;
            loading?.setAttribute('hidden', '');
            invalid?.setAttribute('hidden', '');
            kit?.removeAttribute('hidden');
          })
          .catch(fail);

        let current = 0;
        const pages = [...document.querySelectorAll('[data-page]')];
        const navButtons = [...document.querySelectorAll('[data-go]')];
        const prev = document.querySelector('[data-prev]');
        const next = document.querySelector('[data-next]');
        const counter = document.querySelector('[data-current]');
        const show = (index) => {
          current = Math.max(0, Math.min(pages.length - 1, index));
          pages.forEach((page, i) => page.classList.toggle('is-active', i === current));
          navButtons.forEach((button, i) => button.classList.toggle('is-active', i === current));
          if (prev instanceof HTMLButtonElement) prev.disabled = current === 0;
          if (next instanceof HTMLButtonElement) { next.disabled = current === pages.length - 1; next.textContent = current === pages.length - 1 ? 'Complete' : 'Next →'; }
          if (counter) counter.textContent = String(current + 1);
          window.scrollTo({ top: 0, behavior: matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth' });
        };
        navButtons.forEach((button) => button.addEventListener('click', () => show(Number(button.getAttribute('data-go')))));
        prev?.addEventListener('click', () => show(current - 1));
        next?.addEventListener('click', () => { if (current < pages.length - 1) show(current + 1); });
        document.querySelector('[data-print]')?.addEventListener('click', () => window.print());
        document.querySelectorAll('[data-copy]').forEach((button) => button.addEventListener('click', async () => {
          const target = document.getElementById(button.getAttribute('data-copy') || '');
          if (!target?.textContent) return;
          await navigator.clipboard.writeText(target.textContent);
          const original = button.textContent; button.textContent = 'Copied'; setTimeout(() => { button.textContent = original; }, 1400);
        }));
      })();
    </script>
  </body>
</html>

<style>
  :global(:root) { --kit-ink:#18342c; --kit-muted:#63716b; --kit-cream:#fbf7ee; --kit-paper:#fffdf8; --kit-sage:#dfe8df; --kit-sage-deep:#45685a; --kit-peach:#edb190; --kit-sand:#eee2cf; --kit-border:rgba(24,52,44,.14); }
  :global(*) { box-sizing: border-box; }
  :global(html) { scroll-behavior: smooth; }
  :global(body.kit-body) { margin:0; min-width:320px; background:#edf0ea; color:var(--kit-ink); font-family:'Manrope Variable',sans-serif; }
  .kit-header { position:sticky; top:0; z-index:20; border-bottom:1px solid var(--kit-border); background:rgba(255,253,248,.94); backdrop-filter:blur(16px); }
  .kit-header-inner { width:min(1440px,100% - 40px); min-height:68px; margin:auto; display:flex; align-items:center; justify-content:space-between; gap:24px; }
  .kit-header a { display:flex; }
  .kit-header-meta { display:flex; align-items:center; gap:22px; color:var(--kit-muted); font-size:.78rem; }
  .kit-header-meta b { color:var(--kit-ink); }
  button { font:inherit; }
  .kit-print { border:0; border-radius:999px; padding:10px 15px; background:var(--kit-ink); color:white; cursor:pointer; font-weight:750; }
  .kit-layout { width:min(1440px,100% - 40px); margin:28px auto; display:grid; grid-template-columns:260px minmax(0,1fr); gap:24px; align-items:start; }
  .kit-sidebar { position:sticky; top:96px; min-height:calc(100vh - 124px); padding:28px 22px; display:flex; flex-direction:column; border:1px solid var(--kit-border); border-radius:24px; background:var(--kit-ink); color:white; box-shadow:0 18px 50px rgba(24,52,44,.12); }
  .kit-sidebar > div strong { display:block; margin:8px 0 3px; font:700 1.35rem/1.1 'Newsreader Variable',serif; }
  .kit-sidebar > div span,.kit-sidebar small { color:rgba(255,255,255,.62); font-size:.74rem; line-height:1.5; }
  .kit-kicker { margin:0; color:var(--kit-peach); font-size:.7rem; font-weight:800; letter-spacing:.12em; text-transform:uppercase; }
  .kit-sidebar nav { display:grid; gap:8px; margin:34px 0; }
  .kit-sidebar nav button { width:100%; padding:12px; display:grid; grid-template-columns:28px 1fr; gap:8px; align-items:center; border:1px solid transparent; border-radius:12px; background:transparent; color:rgba(255,255,255,.66); text-align:left; cursor:pointer; }
  .kit-sidebar nav button i { color:var(--kit-peach); font-style:normal; font-size:.65rem; font-weight:800; }
  .kit-sidebar nav button span { font-size:.78rem; font-weight:700; }
  .kit-sidebar nav button.is-active { border-color:rgba(255,255,255,.14); background:rgba(255,255,255,.09); color:white; }
  .kit-sidebar small { margin-top:auto; }
  .kit-stage { min-width:0; }
  .kit-page { display:none; min-height:calc(100vh - 124px); padding:clamp(32px,4.2vw,60px); overflow:hidden; border:1px solid var(--kit-border); border-radius:28px; background:var(--kit-paper); box-shadow:0 18px 50px rgba(24,52,44,.1); }
  .kit-page > * { width:100%; }
  .kit-page.is-active { display:block; animation:kit-in .32s ease both; }
  @keyframes kit-in { from { opacity:0; transform:translateY(7px); } }
  .kit-page-topline { min-height:18px; margin:0 0 clamp(30px,4vw,48px); display:flex; align-items:center; justify-content:space-between; gap:20px; color:var(--kit-muted); font-size:.7rem; font-weight:800; letter-spacing:.1em; text-transform:uppercase; }
  .kit-eyebrow { margin:0 0 10px; color:var(--kit-sage-deep); font-size:.72rem; font-weight:850; letter-spacing:.12em; text-transform:uppercase; }
  .kit-page h1,.kit-page h2,.kit-page h3 { font-family:'Newsreader Variable',serif; }
  .kit-page h1 { max-width:12ch; margin:0; font-size:clamp(3.1rem,7vw,7.4rem); line-height:.88; letter-spacing:-.055em; }
  .kit-page > h2,.kit-section-heading h2 { max-width:18ch; margin:0; font-size:clamp(2.3rem,4.4vw,4.8rem); line-height:.98; letter-spacing:-.035em; }
