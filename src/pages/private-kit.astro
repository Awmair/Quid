  @media (max-width:1050px) {
    .kit-layout { grid-template-columns:1fr; }
    .kit-sidebar { position:static; min-height:0; padding:16px; }
    .kit-sidebar > div,.kit-sidebar > small { display:none; }
    .kit-sidebar nav { margin:0; grid-template-columns:repeat(4,1fr); }
    .kit-sidebar nav button { grid-template-columns:1fr; text-align:center; }
    .kit-flow { grid-template-columns:1fr; gap:8px; }
    .kit-flow > i { transform:rotate(90deg); }
    .kit-flow article { min-height:0; }
    .kit-flow h3 { margin-top:22px; }
    .kit-compare { grid-template-columns:1fr; gap:10px; }
    .kit-vs { margin:-5px 0; }
    .kit-included-grid { grid-template-columns:1fr 1fr; }
  }
  @media (max-width:760px) {
    .kit-header-inner,.kit-layout { width:min(100% - 24px,1440px); }
    .kit-header-meta > span { display:none; }
    .kit-layout { margin:12px auto 24px; gap:12px; }
    .kit-sidebar { overflow:auto; overscroll-behavior-inline:contain; scrollbar-width:thin; }
    .kit-sidebar nav { width:680px; scroll-snap-type:x proximity; }
    .kit-sidebar nav button { min-height:48px; scroll-snap-align:start; }
    .kit-sidebar nav button span { font-size:.68rem; }
    .kit-page { min-height:0; padding:28px 20px; border-radius:20px; }
    .kit-page-topline { margin:0 0 36px; }
    .kit-page-topline span:last-child { max-width:45%; text-align:right; }
    .kit-cover-grid,.kit-commercial-grid,.kit-observation,.kit-section-heading,.kit-workflow-grid,.kit-handoff,.kit-template-grid,.kit-stalled,.kit-final-cta { grid-template-columns:1fr; }
    .kit-cover-grid { align-items:start; }
    .kit-score { width:190px; }
    .kit-audit-grid,.kit-followups,.kit-plan,.kit-metrics { grid-template-columns:1fr 1fr; }
    .kit-section-heading { align-items:start; }
    .kit-rule-card ul { grid-template-columns:1fr; }
    .kit-handoff ul { grid-template-columns:1fr; }
    .kit-stalled-heading { gap:16px; }
    .kit-tracker { overflow:visible; border:0; background:transparent; }
    .kit-tracker-head { display:none; }
    :global(.kit-tracker-row) { margin-top:10px; padding:10px 12px; grid-template-columns:1fr 1fr; gap:6px 14px; border:1px solid var(--kit-border); border-radius:14px; background:white; }
    :global(.kit-tracker-row:first-child) { border-top:1px solid var(--kit-border); }
    :global(.kit-tracker-row span) { min-height:0; padding:5px 0; display:block; border-left:0; background:transparent; text-align:left; }
    :global(.kit-tracker-row span + span) { border-left:0; }
    :global(.kit-tracker-row span:first-child) { justify-content:start; }
    :global(.kit-tracker-row span::before) { content:attr(data-label); display:block; margin-bottom:2px; color:var(--kit-muted); font-size:.52rem; font-weight:850; letter-spacing:.07em; text-transform:uppercase; }
    :global(.kit-tracker-row span:last-child) { grid-column:1 / -1; }
    .kit-final-cta { align-items:start; }
    .kit-cta { justify-self:start; }
    .kit-revenue-strip { grid-template-columns:1fr; }
    .kit-revenue-strip i { transform:rotate(90deg); }
  }
  @media (max-width:520px) {
    .kit-page h1 { font-size:clamp(3rem,16vw,5rem); }
    .kit-page-topline { align-items:flex-start; flex-direction:column; gap:7px; }
    .kit-page-topline span:last-child { max-width:none; text-align:left; }
    .kit-commercial > div { grid-template-columns:1fr; text-align:center; }
    .kit-commercial > div i { transform:rotate(90deg); }
    .kit-template pre,.kit-stalled-copy pre { overflow-wrap:anywhere; word-break:break-word; }
    .kit-controls { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
    .kit-controls span { grid-column:1 / -1; grid-row:1; text-align:center; }
    .kit-controls button { width:100%; min-width:0; }
    .kit-included-grid,.kit-audit-grid,.kit-followups,.kit-plan,.kit-metrics { grid-template-columns:1fr; }
    :global(.kit-audit-card),:global(.kit-followups article),.kit-plan article { min-height:0; }
    .kit-copy-rule { display:grid; }
  }

  @page { size:A4 portrait; margin:10mm; }
  @media print {
    :global(html),:global(body.kit-body) { background:white !important; }
    .kit-header,.kit-sidebar,.kit-controls,.kit-loading,.kit-invalid,.kit-template button { display:none !important; }
    .kit-layout { width:100%; margin:0; display:block; }
    .kit-stage { display:block; }
    .kit-page,.kit-page.is-active { min-height:277mm; padding:8mm; display:block !important; break-after:page; border:0; border-radius:0; box-shadow:none; animation:none; }
    .kit-page:last-of-type { break-after:auto; }
    .kit-page h1 { font-size:34pt; }
    .kit-page > h2 { font-size:24pt; }
    .kit-page-topline { margin:0 0 18px; }
    .kit-page-intro,.kit-lede { font-size:9pt; line-height:1.45; }
    .kit-cover-grid { grid-template-columns:1fr 150px; gap:28px; }
    .kit-score { width:150px; padding:15px; border-width:9px; }
    .kit-score strong { font-size:28pt; }
    .kit-lede { margin:12px 0; }
    .kit-commercial-grid { margin:18px 0 10px; gap:8px; }
