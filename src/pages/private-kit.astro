  .kit-tracker { margin:30px 0 34px; overflow:hidden; border:1px solid var(--kit-border); border-radius:18px; background:white; }
  .kit-tracker-head,:global(.kit-tracker-row) { display:grid; grid-template-columns:.85fr 1.1fr 1.45fr 1fr 2fr; gap:0; align-items:stretch; }
  .kit-tracker-head { background:var(--kit-ink); color:white; }
  .kit-tracker-head span { min-width:0; padding:13px 16px; color:rgba(255,255,255,.72); font-size:.6rem; font-weight:850; letter-spacing:.08em; text-transform:uppercase; }
  .kit-tracker-head span + span { border-left:1px solid rgba(255,255,255,.13); }
