  .kit-final-cta p:last-child { max-width:62ch; margin:10px 0 0; color:rgba(255,255,255,.65); font-size:.75rem; line-height:1.5; }
  .kit-cta { padding:13px 17px; border-radius:999px; background:var(--kit-peach); color:var(--kit-ink); font-size:.76rem; font-weight:850; text-decoration:none; white-space:nowrap; }
  .kit-disclaimer { margin-top:28px; color:var(--kit-muted); font-size:.62rem; line-height:1.5; }
  .kit-disclaimer p { margin:5px 0 0; }
  .kit-controls { margin:16px 4px 0; display:flex; align-items:center; justify-content:space-between; }
