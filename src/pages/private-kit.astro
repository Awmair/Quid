  :global(.kit-tracker-row span) { min-width:0; min-height:64px; padding:15px 16px; display:flex; align-items:center; color:var(--kit-muted); font-size:.7rem; line-height:1.45; overflow-wrap:anywhere; }
  :global(.kit-tracker-row span + span) { border-left:1px solid var(--kit-border); }
  :global(.kit-tracker-row span:first-child) { justify-content:center; background:#fff0e7; color:#a64b31; font-weight:900; text-align:center; }
  :global(.kit-tracker-row span:nth-child(2)),:global(.kit-tracker-row span:nth-child(4)) { color:var(--kit-ink); font-weight:800; }
  .kit-plan-heading { margin:0 0 18px; }
  .kit-plan { margin:0; display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }
  .kit-plan article { min-height:145px; padding:18px; border-top:5px solid var(--kit-sage-deep); border-radius:4px 4px 16px 16px; background:var(--kit-cream); }
  .kit-plan article:nth-child(2) { border-color:#719081; }
  .kit-plan article:nth-child(3) { border-color:var(--kit-peach); }
  .kit-plan article:nth-child(4) { border-color:var(--kit-ink); }
