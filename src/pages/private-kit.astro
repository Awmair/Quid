  :global(.kit-handoff li) { min-height:42px; padding:10px 11px 10px 34px; position:relative; display:flex; align-items:center; border-radius:10px; background:#f4dfd2; font-size:.69rem; font-weight:750; line-height:1.35; }
  :global(.kit-handoff li::before) { content:'!'; position:absolute; left:11px; width:16px; height:16px; display:grid; place-items:center; border-radius:50%; background:#a65337; color:white; font-size:.58rem; font-weight:900; }
  .kit-template-grid { margin:32px 0 34px; display:grid; grid-template-columns:1.2fr .8fr; gap:16px; align-items:stretch; }
  .kit-template { padding:22px; border:1px solid var(--kit-border); border-radius:18px; background:var(--kit-cream); }
  .kit-template.featured { background:var(--kit-sage); }
