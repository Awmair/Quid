  .kit-template > div span { font-size:.68rem; font-weight:850; letter-spacing:.08em; text-transform:uppercase; }
  .kit-template button { padding:6px 9px; border:1px solid var(--kit-border); border-radius:999px; background:white; color:var(--kit-ink); cursor:pointer; font-size:.64rem; font-weight:750; }
