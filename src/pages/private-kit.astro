  .kit-controls button:disabled { opacity:.35; cursor:default; }
  .kit-controls span { color:var(--kit-muted); font-size:.72rem; }
  .kit-loading,.kit-invalid { min-height:calc(100vh - 68px); display:grid; place-content:center; justify-items:center; gap:12px; padding:30px; text-align:center; }
  .kit-loading p,.kit-invalid p { color:var(--kit-muted); }
