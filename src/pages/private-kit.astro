  :global(.kit-metrics strong) { font:700 1.05rem/1.2 'Newsreader Variable',serif; }
  :global(.kit-metrics span) { margin-top:8px; color:var(--kit-muted); font-size:.68rem; line-height:1.45; }
  .kit-final-cta { margin-top:28px; padding:26px; display:grid; grid-template-columns:1fr auto; gap:35px; align-items:center; border-radius:20px; background:var(--kit-ink); color:white; }
