---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';
import { primaryCtaHref, site } from '../data/site';

type OpenGraphType = 'website' | 'article';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  ogType?: OpenGraphType;
  publishedTime?: string;
  modifiedTime?: string;
  noindex?: boolean;
  canonicalUrl?: string | false;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = site.defaultTitle,
  description = site.defaultDescription,
  image = '/quid-og.png',
  imageAlt,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  noindex = false,
  canonicalUrl,
  schema,
} = Astro.props;
const canonical = canonicalUrl === false ? undefined : canonicalUrl || new URL(Astro.url.pathname, site.domain).toString();
const socialImage = new URL(image, site.domain).toString();
const socialImageAlt = imageAlt || `${title} — Quid Admissions`;
const normalizedPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const hideLeadMagnet = ['/privacy', '/terms', '/404', '/404.html'].includes(normalizedPath);
const organizationId = `${site.domain}/#organization`;
const websiteId = `${site.domain}/#website`;
const logoId = `${site.domain}/#logo`;
const globalSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': organizationId,
    name: 'Quid Admissions',
    alternateName: 'Quid',
    url: `${site.domain}/`,
    logo: {
      '@type': 'ImageObject',
      '@id': logoId,
      url: `${site.domain}/favicon-192x192.png`,
      contentUrl: `${site.domain}/favicon-192x192.png`,
      width: 192,
      height: 192,
      caption: 'Quid Admissions',
    },
    image: { '@id': logoId },
    description: 'Quid handles senior living inquiry follow-up and tour scheduling behind the scenes so teams can miss fewer inquiries, book more tours, and spend more time with residents and families.',
    founder: {
      '@type': 'Person',
      '@id': `${site.domain}/about/#umair-qudoos`,
      name: 'Umair Q.',
      jobTitle: 'Founder',
      sameAs: 'https://www.linkedin.com/in/umair-qudoos/',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': websiteId,
    name: 'Quid',
    alternateName: 'Quid Admissions',
    url: `${site.domain}/`,
    publisher: { '@id': organizationId },
    inLanguage: 'en-US',
    description: site.defaultDescription,
  },
];
const pageSchema = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
const allSchema = [...globalSchema, ...pageSchema];
const robotsContent = noindex
  ? 'noindex,follow'
  : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    {site.googleSiteVerification && <meta name="google-site-verification" content={site.googleSiteVerification} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Quid" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:secure_url" content={socialImage} />
    <meta property="og:image:alt" content={socialImageAlt} />
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <meta name="theme-color" content="#1E3D34" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Quid resources" href="/rss.xml" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    {allSchema.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}
    {site.analyticsDomain && <script is:inline defer data-domain={site.analyticsDomain} src="https://plausible.io/js/script.js"></script>}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Header />
    <main id="main-content"><slot />{!hideLeadMagnet && <LeadMagnetCTA />}</main>
    <Footer />
    {!hideLeadMagnet && <a class="sticky-mobile-cta" href={primaryCtaHref}>See How Quid Fits</a>}
    <script>
      const reveals = document.querySelectorAll<HTMLElement>('[data-reveal]');
      if ('IntersectionObserver' in window && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const observer = new IntersectionObserver((entries) => entries.forEach((entry) => {
          if (entry.isIntersecting) { entry.target.classList.add('is-visible'); observer.unobserve(entry.target); }
        }), { threshold: 0.12 });
        reveals.forEach((item) => observer.observe(item));
      } else reveals.forEach((item) => item.classList.add('is-visible'));

      const stickyMobileCta = document.querySelector<HTMLElement>('.sticky-mobile-cta');
      const siteFooter = document.querySelector<HTMLElement>('.site-footer');
      const mobileViewport = window.matchMedia('(max-width: 760px)');
      const updateStickyMobileCta = () => {
        if (!stickyMobileCta) return;
        const pastOpening = window.scrollY > Math.min(480, window.innerHeight * .65);
        const footerIsVisible = Boolean(siteFooter && siteFooter.getBoundingClientRect().top < window.innerHeight - 18);
        stickyMobileCta.classList.toggle('is-visible', mobileViewport.matches && pastOpening && !footerIsVisible);
      };
      updateStickyMobileCta();
      window.addEventListener('scroll', updateStickyMobileCta, { passive: true });
      window.addEventListener('resize', updateStickyMobileCta, { passive: true });
      mobileViewport.addEventListener?.('change', updateStickyMobileCta);
    </script>
  </body>
</html>
