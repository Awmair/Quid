---
import { pilotWeeks } from '../data/pilot';

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<div class:list={['pilot-timeline', { 'pilot-timeline-full': !compact }]} aria-label="Thirty-day pilot timeline" data-reveal>
  {pilotWeeks.map((item, index) => (
    <article class="pilot-week-card" style={`--week-index:${index}`}>
      <div class="pilot-week-intro">
        <header>
          <span class="pilot-week-icon" aria-hidden="true">{item.icon}</span>
          <div><p>{item.week}</p><h3>{compact ? item.previewTitle : item.title}</h3></div>
        </header>
        <p class="pilot-week-summary">{compact ? item.preview : item.detail}</p>
      </div>
      {compact ? (
        <div class="pilot-deliverables">
          <strong>Deliverables</strong>
          <ul>{item.deliverables.map((deliverable) => <li>{deliverable}</li>)}</ul>
        </div>
      ) : (
        <div class="pilot-week-detail">
          <div><strong>{item.actionLabel}</strong><ul>{item.actions.map((action) => <li>{action}</li>)}</ul></div>
          <div class="pilot-week-output"><strong>Output</strong><ul>{item.output.map((output) => <li>{output}</li>)}</ul></div>
        </div>
      )}
    </article>
  ))}
</div>
