---
interface Item { label: string; href?: string }
const { items } = Astro.props as { items: Item[] };
const sectionHrefs: Record<string, string> = {
  Solutions: '/solutions/',
  Resources: '/resources/',
};
---
<nav class="breadcrumbs shell" aria-label="Breadcrumb">
  <ol>
    {items.map((item, index) => {
      const isCurrent = index === items.length - 1;
      const href = isCurrent ? undefined : item.href || sectionHrefs[item.label];
      return <li>{href ? <a href={href}>{item.label}</a> : <span aria-current={isCurrent ? 'page' : undefined}>{item.label}</span>}</li>;
    })}
  </ol>
</nav>
