---
import { dashboardColumns, dashboardStats } from '../data/dashboardData';

interface Props {
  compact?: boolean;
  headingLevel?: 'h2' | 'h3';
}

const { compact = false, headingLevel = 'h3' } = Astro.props;
const Heading = headingLevel;
---

<div class:list={['product-dashboard', { 'product-dashboard-compact': compact }]} role="region" aria-label="Quid optional manager and exception view" data-reveal>
  <div class="product-dashboard-bar">
    <span class="dashboard-dots" aria-hidden="true"><i></i><i></i><i></i></span>
    <Heading>Quid — Willow Creek Admissions</Heading>
    <span class="data-label">Manager &amp; exception view</span>
  </div>

  <div class="dashboard-stat-row" role="list" aria-label="Daily admissions totals">
    {dashboardStats.map((stat) => (
      <div class="dashboard-stat" role="listitem">
        <span class="dashboard-stat-icon" aria-hidden="true">{stat.icon}</span>
        <strong>{stat.value}</strong>
        <small>{stat.label}</small>
      </div>
    ))}
  </div>

  <div class="dashboard-board">
    {dashboardColumns.map((column) => (
      <section class:list={['dashboard-column', `dashboard-column-${column.id}`]} aria-labelledby={`dashboard-${compact ? 'preview' : 'full'}-${column.id}`}>
        <header><span class="status-dot" aria-hidden="true"></span><h3 id={`dashboard-${compact ? 'preview' : 'full'}-${column.id}`}>{column.label}</h3><span>{column.cards.length}</span></header>
        {column.cards.map((card) => (
          <article class="dashboard-lead-card">
            <strong>{card.name}</strong>
            <dl>
              {card.details.map(([label, value], index) => (!compact || index === 0) && <><dt>{label}</dt><dd>{value}</dd></>)}
            </dl>
            <p class="dashboard-card-status"><span aria-hidden="true">✓</span>{card.status}</p>
            {card.nextAction && <p class="dashboard-next"><small>Next</small>{card.nextAction}</p>}
          </article>
        ))}
      </section>
    ))}
  </div>
</div>
