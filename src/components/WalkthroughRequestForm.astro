<form class="walkthrough-form" action="https://formspree.io/f/mnjkzyak" method="POST" data-walkthrough-form>
  <header class="walkthrough-form-head">
    <p class="eyebrow">Walkthrough request</p>
    <h3>Share the basics.</h3>
    <p>Required fields are marked with <span aria-hidden="true">*</span><span class="visually-hidden">an asterisk</span>.</p>
  </header>

  <div class="walkthrough-form-grid">
    <label>
      <span>First name <b aria-hidden="true">*</b></span>
      <input type="text" name="first_name" autocomplete="given-name" required />
    </label>

    <label>
      <span>Work email <b aria-hidden="true">*</b></span>
      <input type="email" name="email" autocomplete="email" required />
    </label>

    <label>
      <span>Community name <b aria-hidden="true">*</b></span>
      <input type="text" name="community_name" autocomplete="organization" required />
    </label>

    <label>
      <span>Role</span>
      <input type="text" name="job_title" autocomplete="organization-title" />
    </label>

    <label>
      <span>Website</span>
      <input type="url" name="website" autocomplete="url" inputmode="url" />
    </label>

    <label>
      <span>Number of locations</span>
      <input type="number" name="number_of_locations" min="1" inputmode="numeric" />
    </label>

    <div class="walkthrough-form-safety walkthrough-form-wide" role="note">
      <strong>Admissions workflow only</strong>
      <p>Please describe your admissions workflow only. Do not submit resident names, diagnoses, medications, payment information, or medical details.</p>
    </div>

    <label class="walkthrough-form-wide">
      <span>What would you like to see?</span>
      <textarea name="demo_interest" placeholder="Example: inquiry follow-up, tour scheduling, dashboard, human handoffs, or the 30-day pilot."></textarea>
    </label>
  </div>

  <input type="hidden" name="form_type" value="Meet Quid Walkthrough Request" />
  <input type="hidden" name="source_page" value="/meet-quid" />
  <input type="hidden" name="_subject" value="New Meet Quid Request" />
  <div class="walkthrough-form-honeypot" aria-hidden="true">
    <label for="walkthrough-gotcha">Leave this field empty</label>
    <input id="walkthrough-gotcha" type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
  </div>

  <button class="button walkthrough-submit" type="submit">Request Walkthrough</button>
  <p class="walkthrough-helper">We will review your request and follow up if Quid looks relevant for your admissions process.</p>
  <p class="walkthrough-status" aria-live="polite" data-walkthrough-status></p>
</form>

<script>
  document.querySelectorAll<HTMLFormElement>('[data-walkthrough-form]').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      if (!form.checkValidity()) {
        event.preventDefault();
        form.reportValidity();
        return;
      }

      event.preventDefault();
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const status = form.querySelector<HTMLElement>('[data-walkthrough-status]');
      if (!button || !status) return;

      const originalLabel = button.textContent || 'Request Walkthrough';
      button.disabled = true;
      button.setAttribute('aria-busy', 'true');
      button.textContent = 'Sending…';
      status.textContent = '';
      status.removeAttribute('data-state');

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (!response.ok) throw new Error('Submission failed');

        form.reset();
        status.dataset.state = 'success';
        status.textContent = 'Request received. We’ll review your workflow and follow up soon.';
      } catch {
        status.dataset.state = 'error';
        status.textContent = 'Something went wrong. Please try again or contact us directly.';
      } finally {
        button.disabled = false;
        button.removeAttribute('aria-busy');
        button.textContent = originalLabel;
      }
    });
  });
</script>
